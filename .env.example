# Environment Variables
# Copy this file to .env.local and update with your values

# Backend API Configuration
# Development: http://localhost:5000 (or http://localhost:5000/api if your backend uses /api prefix)
# Production: https://your-production-domain.com (or https://your-production-domain.com/api)
VITE_API_BASE_URL=http://localhost:5000

# App Configuration
VITE_APP_NAME=React Production App
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
